# Build artifacts
build/
dist/
**/hevolveai_manifest.json
**/release_manifest.json
Output/
hartos_backend_src/
landing-page/build/     # React build output - regenerated by npm run build
static/landing-page/    # Old build artifacts - should not be tracked
site/                   # MkDocs static-site output - regenerated by mkdocs build / docs.yml
*.exe
!Nunba.exe

# Embedded Python pip packages (1.4 GB - installed by build.py at build time)
python-embed/Lib/site-packages/
python-embed/Scripts/

# Snapshot / backup copies of python-embed left by rebuild_python_embed.py
# — thousands of files each, must NEVER be committed.
python-embed-*backup/
python-embed.hash

# Coverage outputs (generated by pytest-cov + coverage.py)
.coverage
.coverage.*
coverage.xml
.coverage-html/

# WebView2 bootstrapper (downloaded during build)
MicrosoftEdgeWebview2Setup.exe

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local config (may contain secrets)
.env
.env.local
.env.production
# BUT track .env.development (build flags only, no secrets)
!landing-page/.env.development
*.local.json
secrets.json

# Node modules (should be installed fresh)
node_modules/
landing-page/node_modules/

# Package locks (can cause issues across platforms)
# package-lock.json  # Uncomment if causing issues

# Temporary files
*.tmp
*.temp
nul
*.stackdump

# Test/debug scripts (root-level only)
/test_launch*.ps1
/test_source_launch.bat
/test_splash.py
/run_voice_tests.ps1
/debug_hang.py
/debug_startup.py
/test_server_debug.py


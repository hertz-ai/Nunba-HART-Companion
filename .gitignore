/source_launch_stderr.txt
/source_launch_stdout.txt
/flask_app.log
/staged_js_files.txt

# Analysis/plan docs (personal)
/gapanalysisforsathish.*
/planforsathish.md

# Bootstrap scripts (large, downloadable)
/get-pip.py

# pytest
.pytest_cache/

# Backup venvs
.venv.bak/

# Database files (contain user data)
*.db
*.sqlite
*.sqlite3

# TrueFlow runtime injector (deployed by plugin, not source)
.pycharm_plugin/

# Runtime agent data (user-specific, machine-generated)
agent_data/
langchain_config.json

# MCP server config (local dev tool)
.mcp.json

# Business/sales documents (not source code, kept on disk only)
Hevolve_Sales_Outreach_Embodied_AI.md
outreach_sender.html

# Claude Code — personal state only. Agent specs, project hooks, and the
# shared agent workspace are TRACKED.
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/settings.json
!.claude/shared/
!.claude/shared/**

# Credentials and keys
*.pem
*.key
credentials.json
service-account.json
/static/landing-page/static/
config.json
*.pem
master_private_key*
bench/results/

# Journey-suite run artifacts (regenerated each pytest run)
tests/journey/run.log
tests/journey/results.xml
tests/journey/results_*.xml

# Coverage harness generated outputs (keep scripts + docs, drop outputs)
tests/coverage/python/
tests/coverage/js/
